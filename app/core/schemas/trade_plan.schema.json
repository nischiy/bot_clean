{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "symbol": {"type": "string"},
    "side": {"type": "string", "enum": ["BUY", "SELL"]},
    "type": {"type": "string", "enum": ["MARKET", "LIMIT"]},
    "quantity": {"type": "number"},
    "price": {"type": "number"},
    "client_order_id": {"type": "string"},
    "timeframe": {"type": "string"},
    "action": {"type": "string", "enum": ["OPEN", "CLOSE", "UPDATE_SLTP"]},
    "stop_loss": {
      "type": "object",
      "required": ["price", "client_order_id"],
      "properties": {
        "price": {"type": "number"},
        "client_order_id": {"type": "string"},
        "quantity": {"type": "number"}
      }
    },
    "take_profit": {
      "type": "object",
      "required": ["price", "client_order_id"],
      "properties": {
        "price": {"type": "number"},
        "client_order_id": {"type": "string"}
      }
    },
    "tp_orders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "take_price", "qty", "reduce_only", "client_order_id"],
        "properties": {
          "type": {"type": "string", "enum": ["TAKE_PROFIT_MARKET"]},
          "take_price": {"type": "number"},
          "qty": {"type": "number"},
          "reduce_only": {"type": "boolean"},
          "client_order_id": {"type": "string"}
        }
      }
    },
    "leverage": {"type": "integer"},
    "margin_type": {"type": "string", "enum": ["isolated", "cross"]},
    "timestamp": {"type": "integer"}
  },
  "oneOf": [
    {
      "required": [
        "symbol",
        "side",
        "type",
        "quantity",
        "client_order_id",
        "stop_loss",
        "action"
      ],
      "properties": {
        "action": {"const": "OPEN"}
      },
      "anyOf": [
        {"required": ["take_profit"]},
        {"required": ["tp_orders"]}
      ]
    },
    {
      "required": [
        "symbol",
        "side",
        "type",
        "quantity",
        "client_order_id",
        "action"
      ],
      "properties": {
        "action": {"const": "CLOSE"}
      }
    },
    {
      "required": [
        "symbol",
        "side",
        "type",
        "client_order_id",
        "stop_loss",
        "action"
      ],
      "properties": {
        "action": {"const": "UPDATE_SLTP"}
      }
    }
  ]
}
