{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["intent", "reject_reasons"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["LONG", "SHORT", "HOLD", "CLOSE", "UPDATE_SLTP"]
    },
    "directional_intent": {
      "type": "string",
      "enum": ["LONG", "SHORT", "NEUTRAL"]
    },
    "reject_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "missing_fields": {
      "type": "array",
      "items": {"type": "string"}
    },
    "entry": {
      "type": "number"
    },
    "sl": {
      "type": "number"
    },
    "tp": {
      "type": "number"
    },
    "rr": {
      "type": "number"
    },
    "tp_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["price", "rr", "qty_frac"],
        "properties": {
          "price": {"type": "number"},
          "rr": {"type": "number"},
          "qty_frac": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "execution_decision": {
      "type": "string",
      "enum": [
        "HOLD",
        "OPEN_LONG_EARLY",
        "OPEN_LONG_CONFIRMED",
        "OPEN_SHORT_EARLY",
        "OPEN_SHORT_CONFIRMED",
        "HOLD_LATE",
        "HOLD_EVENT",
        "HOLD_LOW_QUALITY",
        "CLOSE",
        "UPDATE_SLTP"
      ]
    },
    "execution_outcome": {
      "type": "string"
    },
    "entry_mode": {
      "type": "string",
      "enum": ["NONE", "EARLY", "CONFIRMED"]
    },
    "hold_reason": {
      "type": ["string", "null"],
      "enum": ["NEUTRAL_MARKET", "UNCONFIRMED_DIRECTION", "PLAN_BUILD_FAILED", null]
    },
    "final_authority_stage": {
      "type": "string",
      "enum": [
        "TIME_EXIT",
        "HARD_BLOCK",
        "LEGACY_CONFIRMED",
        "PREDICTIVE_EARLY",
        "QUALITY_REJECT",
        "EVENT_REJECT",
        "LATE_REJECT",
        "ROUTER_REJECT"
      ]
    },
    "predictive_authority": {
      "type": "string",
      "enum": ["NONE", "PROBE", "EXECUTABLE"]
    },
    "decision_engine_outcome": {
      "type": "string"
    },
    "runtime_profile_version": {
      "type": "string"
    },
    "timeframe_decision": {
      "type": "string"
    },
    "logic_family": {
      "type": "string"
    },
    "signal": {
      "type": "object"
    },
    "state_update": {
      "type": "object"
    },
    "move_sl_to_be_after_tp1": {
      "type": "boolean"
    },
    "strategy": {
      "type": "string"
    },
    "timestamp": {
      "type": "integer"
    }
  }
}
