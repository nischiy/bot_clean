{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["intent", "reject_reasons"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["LONG", "SHORT", "HOLD", "CLOSE"]
    },
    "reject_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "entry": {
      "type": "number"
    },
    "sl": {
      "type": "number"
    },
    "tp": {
      "type": "number"
    },
    "rr": {
      "type": "number"
    },
    "tp_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["price", "rr", "qty_frac"],
        "properties": {
          "price": {"type": "number"},
          "rr": {"type": "number"},
          "qty_frac": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "move_sl_to_be_after_tp1": {
      "type": "boolean"
    },
    "strategy": {
      "type": "string"
    },
    "timestamp": {
      "type": "integer"
    }
  }
}
