# Runtime / Mode
ENV=production
# Recommended safe readonly profile (paper mirror)
SAFE_RUN=1
LIVE_READONLY=1
REPLAY_MODE=0
OFFLINE_MODE=0
PAPER_TRADING=1
TRADE_ENABLED=0
DRY_RUN_ONLY=1
FORCE_RECONCILE=0
DOTENV_DISABLE=0
APP_RUN_ONESHOT=0
RUNTIME_MODE=

# State / Ledger
STATE_DIR=run/state
LEDGER_DIR=run/ledger
LEDGER_ENABLED=1

# Exchange / Symbol / Timeframes
EXCHANGE=binance_futures
SYMBOL=BTCUSDT
INTERVAL=5m
HTF_INTERVAL=1h
QUOTE_ASSET=USDT
BINANCE_TESTNET=0
BINANCE_FAPI_BASE=https://fapi.binance.com
BASE_URL_MAINNET=https://fapi.binance.com
BASE_URL_TESTNET=https://testnet.binancefuture.com
MARKET_DATA_MODULE=app.services.market_data
BINANCE_RECV_WINDOW=5000
BINANCE_TIME_OFFSET_TTL_SEC=60

# API Keys (required for production live; still listed here)
